<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ctg.release</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/chethan356/Programming/CTG/scripts/daily_release.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/chethan356/Programming/CTG</string>

  <!-- fire once a day at 11:00 (runs on next wake if the Mac was asleep) -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>11</integer>
    <key>Minute</key><integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/chethan356/Programming/CTG/logs/release.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/chethan356/Programming/CTG/logs/release.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
</dict>
</plist>
