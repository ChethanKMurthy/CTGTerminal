# =====================================================================
# CTG — Autonomous Alpha Discovery System (India)  —  configuration
# Copy this file to ".env" and fill in the free API keys you obtain.
# Every key is OPTIONAL: the system runs without it, but the layers that
# depend on it stay dark until provided. Get all of these for free.
# =====================================================================

# --- LLM agent reasoning (need at least ONE of these two) ---
# Google Gemini  -> https://aistudio.google.com/apikey  (free tier, generous)
GEMINI_API_KEY=
# Groq (fast Llama/Qwen) -> https://console.groq.com/keys  (free tier)
GROQ_API_KEY=
# Which provider to prefer first: "gemini" or "groq"
LLM_PRIMARY=gemini

# --- Macro data ---
# FRED (US Fed) -> https://fredaccount.stlouisfed.org/apikeys  (free, instant)
FRED_API_KEY=

# --- Social sentiment (Reddit) ---
# Create an app -> https://www.reddit.com/prefs/apps  (type: "script")
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ctg-india-alpha/0.1 by yourusername

# --- Alerts: Telegram ---
# 1) Message @BotFather on Telegram -> /newbot -> get token
# 2) Message your new bot once, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Alerts: Email (optional, Gmail app password) ---
# Gmail -> enable 2FA -> create App Password -> https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# --- Runtime ---
# Web dashboard bind
WEB_HOST=127.0.0.1
WEB_PORT=8799
# Log level
LOG_LEVEL=INFO
